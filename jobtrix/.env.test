# ACHTUNG: Diese Datei enthält ausschließlich unkritische Testwerte für NODE_ENV=test.
# Produktive Secrets (DATABASE_URL, NEXTAUTH_SECRET, STRIPE_*, RESEND_API_KEY etc.)
# dürfen hier NIEMALS eingetragen werden.
# Produktive Secrets werden ausschließlich über Render-Umgebungsvariablen
# oder lokal über .env.local gesetzt. .env.local ist in .gitignore eingetragen.
#
# Testwerte fuer die Jest-Testumgebung (NODE_ENV=test).
# Kein echtes Secret - wird nur lokal von signierten Reset-Tokens in Tests verwendet.
NEXTAUTH_SECRET=test-secret-not-for-production-use-0123456789
