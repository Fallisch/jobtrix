generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  name          String?
  image         String?
  emailVerified DateTime?

  hasSeenWelcome Boolean @default(false)

  accounts Account[]
  sessions Session[]
  profile  UserProfile?
  access   Access?

  applicationHistory ApplicationHistoryEntry[]
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String   @default("")
  address        String   @default("")
  email          String   @default("")
  phone          String   @default("")
  birthdate      String   @default("")
  photo          String?  @db.Text
  education      Json     @default("[]")
  experience     Json     @default("[]")
  qualifications Json     @default("[]")
  interests      Json     @default("[]")
  themePreference String  @default("system")
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AccessPackage {
  none
  limited
  lifetime
}

model Access {
  id                 String        @id @default(cuid())
  userId             String        @unique
  freeGenerationUsed Boolean       @default(false)
  package            AccessPackage @default(none)
  validUntil         DateTime?
  stripePaymentId    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApplicationHistoryEntry {
  id              String   @id @default(cuid())
  userId          String
  createdAt       DateTime @default(now())
  jobTitle        String?
  companyName     String?
  emailSubject    String
  coverLetter     String   @db.Text
  cv              String   @db.Text
  emailBody       String?  @db.Text
  profileSnapshot Json
  template        String   @default("classic")
  accentColor     String?
  cvStyle         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RateLimitEntry {
  id          String   @id @default(cuid())
  key         String   @unique
  windowStart DateTime @default(now())
  attempts    Int      @default(0)
}

model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  processedAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ArchivedPayment {
  id              String        @id @default(cuid())
  stripePaymentId String
  package         AccessPackage
  createdAt       DateTime      @default(now())
  deletedAt       DateTime      @default(now())
}
