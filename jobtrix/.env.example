ANTHROPIC_API_KEY=

# NextAuth Secret - generieren z. B. mit: openssl rand -base64 32
NEXTAUTH_SECRET=

# DATABASE_URL und NEXTAUTH_URL haben fuer die lokale Entwicklung Defaults in .env
# (siehe docker-compose.yml). Fuer Produktion ueberschreiben:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# NEXTAUTH_URL=https://example.com

# Direkte (ungepoolte) DB-Verbindung fuer Prisma-Migrationen. Das Schema
# verlangt directUrl = env("DIRECT_DATABASE_URL"). Bei Supabase ist das die
# Direct Connection (Port 5432, nicht der Pooler 6543). Ohne Pooler identisch
# mit DATABASE_URL.
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Stripe Test-Mode Secret Key (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=

# Stripe Webhook Signing Secret (https://dashboard.stripe.com/test/webhooks)
STRIPE_WEBHOOK_SECRET=

# Preise und Laufzeiten fuer die Pakete (Platzhalterwerte)
# PRICE_LIMITED_EUR=12.99
# PRICE_LIMITED_DURATION_DAYS=30
# PRICE_LIFETIME_EUR=34.99
# PRICE_MONTHLY_EUR=9.99
# PRICE_YEARLY_EUR=89.99

# Resend API-Key fuer den Versand von Transaktions-E-Mails (https://resend.com/api-keys)
RESEND_API_KEY=

# Absender-E-Mail-Adresse fuer Resend (Format: "Name <email>")
RESEND_FROM_EMAIL=JobTRIX <noreply@jobtrix.de>

# API-Key fuer die Jobsuche-API der Bundesagentur fuer Arbeit (X-API-Key Header).
# Die inoffizielle API benoetigt keine eigene Registrierung; der oeffentlich
# bekannte Default-Wert der BA-Jobsuche-App ist "jobboerse-jobsuche".
# ARBEITSAGENTUR_API_KEY=jobboerse-jobsuche

# Wartungsmodus: "true" zeigt allen Besuchern eine Wartungsseite
# MAINTENANCE_MODE=true
